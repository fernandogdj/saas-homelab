# =============================================================
# .env — copie para .env e preencha
# =============================================================

# IP fixo do seu servidor no homelab (ex: 192.168.1.100)
SERVER_IP=192.168.1.100

# Timezone
TZ=America/Sao_Paulo

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=troque_esta_senha_forte

# --- PostgreSQL (compartilhado entre Listmonk e Outline) ---
PG_USER=selfhost
PG_PASSWORD=troque_esta_senha_pg

# --- MinIO (storage do Outline) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=troque_esta_senha_minio

# --- Outline ---
# Gere duas chaves com: openssl rand -hex 32
OUTLINE_SECRET_KEY=cole_aqui_64_chars_hex
OUTLINE_UTILS_SECRET=cole_aqui_64_chars_hex_diferente
